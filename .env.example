# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  SAFE TEMPLATE, commit this file
# Copy to .env and fill in real values:  cp .env.example .env
# .env is listed in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# HamAlert credentials (https://hamalert.org)
HA_USERNAME=YOUR_CALLSIGN
HA_PASSWORD=YOUR_HAMALERT_PASSWORD

# Gmail sender account + App Password
# How to get an App Password:
#   Google Account → Security → 2-Step Verification (enable) →
#   https://myaccount.google.com/apppasswords → Mail → Other
GMAIL_USER=your-bot-account@gmail.com
GMAIL_APP_PW=xxxx xxxx xxxx xxxx

# Destination e-mail address for spot notifications
EMAIL_TO=your-callsign@example.com

# Optional tuning (safe to leave at defaults)
BATCH_SIZE=1          # spots per email (1 = instant delivery)
RECONNECT_DELAY=30    # seconds before reconnect after a dropped connection
